{
  "name": "ananke",
  "version": "0.1.0",
  "private": true,
  "description": "Project Ananke — MCP Outcome Gateway: typed outcomes, approval binding, and audit for AI agent tool calls",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint packages --ext .ts",
    "format": "prettier --write packages",
    "dev:gateway": "npm run dev -w @ananke/gateway",
    "dev:dashboard": "npm run dev -w @ananke/dashboard",
    "test:bench": "npm run test -w @ananke/testbench"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
